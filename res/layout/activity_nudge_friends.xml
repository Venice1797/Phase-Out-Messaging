<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- "Tell me more…" button -->
        <Button
            android:id="@+id/nudge_tell_me_more_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nudge_tell_me_more"
            android:drawableStart="@drawable/ic_info"
            android:drawableTint="#FFFFFF"
            android:drawablePadding="8dp"
            android:backgroundTint="#006FFF"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            style="?android:attr/buttonStyle" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"
            android:background="?android:attr/listDivider" />

        <!-- "Recommended Privacy App" section heading -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nudge_privacy_app_section"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <!-- Privacy app name field -->
        <EditText
            android:id="@+id/nudge_privacy_app_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:text="@string/nudge_privacy_app_default"
            android:textSize="16sp"
            android:singleLine="true"
            android:background="@drawable/edit_text_border" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            android:background="?android:attr/listDivider" />

        <!-- "Auto Reply" section heading -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_reply_section"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <!-- Toggle row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <Switch
                android:id="@+id/auto_reply_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_reply_toggle_label"
                android:textSize="15sp"
                android:paddingStart="12dp"
                android:textColor="?android:attr/textColorPrimary" />

        </LinearLayout>

        <!-- Auto Reply content container (grayed out when toggle is off) -->
        <LinearLayout
            android:id="@+id/auto_reply_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Audience selector -->
            <RadioGroup
                android:id="@+id/auto_reply_audience_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp">

                <RadioButton
                    android:id="@+id/auto_reply_audience_everyone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_reply_audience_everyone"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/auto_reply_audience_contacts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_reply_audience_contacts" />

                <RadioButton
                    android:id="@+id/auto_reply_audience_unknowns"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_reply_audience_unknowns" />

            </RadioGroup>

            <!-- Spinner label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_reply_choose_message"
                android:textSize="15sp"
                android:textColor="?android:attr/textColorPrimary"
                android:paddingBottom="4dp" />

            <!-- Template dropdown -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/edit_text_border">

                <Spinner
                    android:id="@+id/auto_reply_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="17dp"
                    android:background="@drawable/spinner_background"
                    android:paddingEnd="72dp" />

            </LinearLayout>

            <!-- Message preview / custom text field -->
            <EditText
                android:id="@+id/auto_reply_message_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:gravity="top|start"
                android:textSize="15sp"
                android:background="@drawable/edit_text_border" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            android:background="?android:attr/listDivider" />

        <!-- "A short nudge message" section heading -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nudge_message_section"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <!-- Nudge message field -->
        <EditText
            android:id="@+id/nudge_message_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:gravity="top|start"
            android:textSize="15sp"
            android:background="@drawable/edit_text_border" />

        <!-- Reset message button -->
        <Button
            android:id="@+id/nudge_reset_message_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/nudge_reset_message"
            android:backgroundTint="#006FFF"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            style="?android:attr/buttonStyle" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            android:background="?android:attr/listDivider" />

        <!-- "A longer nudge message" section heading -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nudge_long_message_section"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <!-- Long nudge message field -->
        <EditText
            android:id="@+id/nudge_long_message_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="4"
            android:gravity="top|start"
            android:textSize="15sp"
            android:background="@drawable/edit_text_border" />

        <!-- Reset long message button -->
        <Button
            android:id="@+id/nudge_reset_long_message_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/nudge_reset_message"
            android:backgroundTint="#006FFF"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            style="?android:attr/buttonStyle" />

    </LinearLayout>

</ScrollView>
